{
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "framework": null,
    "functions": {
      "api/nosy.js": {
        "maxDuration": 30
      },
      "api/nosy-email.js": {
        "maxDuration": 30
      }
    },
    "rewrites": [
      {
        "source": "/((?!api/.*).*)",
        "destination": "/index.html"
      }
    ]
  }
